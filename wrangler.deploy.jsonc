{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "saybackend",
  "main": "./src/worker.js",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "run_worker_first": true,
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "saybackend.com",
    },
    {
      "custom_domain": true,
      "pattern": "www.saybackend.com",
    },
  ],
}
